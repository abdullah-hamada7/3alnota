{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=BillSplitter;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  },
  "SessionTokens": {
    "SigningKey": "YOUR_SECRET_SIGNING_KEY_MIN_32_CHARS_LONG",
    "Issuer": "BillSplitterApi",
    "Audience": "BillSplitterApp"
  }
}
